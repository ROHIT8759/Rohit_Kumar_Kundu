generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VisitorAnalytics {
  id                  String          @id @default(cuid())
  visitId             String          @db.VarChar(128)
  path                String
  url                 String
  referrer            String?
  userAgent           String?
  ipAddress           String?         @db.VarChar(128)
  forwardedFor        String?
  city                String?
  region              String?
  country             String?
  latitude            Float?
  longitude           Float?
  timezone            String?
  timezoneOffset      Int?
  language            String?
  languages           Json?
  platform            String?
  deviceMemoryGb      Float?
  hardwareConcurrency Int?
  screenWidth         Int?
  screenHeight        Int?
  viewportWidth       Int?
  viewportHeight      Int?
  colorDepth          Int?
  pixelRatio          Float?
  touchPoints         Int?
  cookieEnabled       Boolean?
  doNotTrack          String?
  online              Boolean?
  connectionType      String?
  effectiveType       String?
  downlinkMbps        Float?
  rttMs               Int?
  durationMs          Int?
  startedAt           DateTime?
  endedAt             DateTime?
  metadata            Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  action              AnalyticsAction
  eventAt             DateTime        @default(now())

  @@index([eventAt(sort: Desc)])
  @@index([visitId, eventAt(sort: Desc)])
  @@index([action, eventAt(sort: Desc)])
  @@index([ipAddress])
  @@index([path])
  @@index([country, eventAt(sort: Desc)])
}

enum AnalyticsAction {
  START
  HEARTBEAT
  END
}
